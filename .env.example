# Image Generation (Required)
GEMINI_API_KEY=your_gemini_key_here
OPENAI_API_KEY=your_openai_key_here

# Printify - Primary POD Platform (Required for API automation)
PRINTIFY_API_TOKEN=your_printify_token_here
PRINTIFY_SHOP_ID=your_shop_id_here

# Redbubble - Secondary POD Platform (Optional, uses browser automation)
REDBUBBLE_EMAIL=your_email_here
REDBUBBLE_PASSWORD=your_password_here

# Pinterest - Social Promotion (Optional)
PINTEREST_ACCESS_TOKEN=your_pinterest_token_here
PINTEREST_BOARD_ID=your_board_id_here
